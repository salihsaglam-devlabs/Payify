{
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://0.0.0.0:5010"
      }
    }
  },
  "AllowedHosts": "*",
  "WalletSettings": {
    "MaxWalletCreationLimit": "10"
  },
  "DefaultWalletSettings": {
    "CurrencyCode": "TRY",
    "FriendlyName": "İlk Hesabım"
  },
  "DatabaseProvider": "PostgreSql",
  "LongQueryLogger": {
    "MaxDurationLimit": 10000
  }
}
