{
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://0.0.0.0:5020"
      }
    }
  },
  "AllowedHosts": "*",
  "PasswordValidation": {
    "RepetitiveRegexPattern": "([0-9])\\1{3}",
    "SuccessiveRegexPattern": "(((012345)|(543210)|(123456)|(654321)|(234567)|(765432)|(345678)|(876543)|(456789)|(987654))){1}",
    "CurrentPasswordCharValues": "0123456789"
  },
  "LongQueryLogger": {
    "MaxDurationLimit": 5000
  }
}