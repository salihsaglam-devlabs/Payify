{
  "HealthChecks-UI": {
    "HealthChecks": [
      {
        "Name": "Tools",
        "Uri": "http://localhost:5025/tools-health"
      },
      {
        "Name": "Services",
        "Uri": "http://localhost:5025/services-health"
      }
    ],
    "EvaluationTimeInSeconds": 300,
    "MinimumSecondsBetweenFailureNotifications": 3600
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
